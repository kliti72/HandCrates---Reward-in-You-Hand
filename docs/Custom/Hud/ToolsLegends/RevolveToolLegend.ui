$LegendCommon = "ToolsLegendsCommon.ui";

$LegendCommon.@Legend {
  #Pages {
    $LegendCommon.@Page #Page1Basics {
      @Title = %client.builderTools.legend.RevolveTool.Page1.Title;

      $LegendCommon.@RowLabel {
        Text: %client.builderTools.legend.RevolveTool.Page1.Description;
        Padding: (Vertical: 8);
      }

      $LegendCommon.@HotkeyRow {
        @InputBindingKey = "SecondaryItemAction";
        @Description = %client.builderTools.legend.RevolveTool.Page1.ShapeArea;
      }

      $LegendCommon.@Separator {}

      $LegendCommon.@HotkeyRow {
        @InputBindingKey = "UndoItemAction";
        @Description = %client.builderTools.legend.UndoLastBrush;
      }

      $LegendCommon.@HotkeyRow {
        @InputBindingKey = "RedoItemAction";
        @Description = %client.builderTools.legend.RedoLastUndo;
      }

    }

    $LegendCommon.@Page #Page2TipsAndTricks {
      @Title = %client.builderTools.legend.TipsAndTricks.Title;

      $LegendCommon.@RowLabel {
        Text: %client.builderTools.legend.TipsAndTricks.Description;
        Padding: (Vertical: 8);
      }

      $LegendCommon.@Separator {}

      $LegendCommon.@TitledRow {
        @Name = %client.builderTools.legend.RevolveTool.Page2.Example1.Title;
        @Description = %client.builderTools.legend.RevolveTool.Page2.Example1.Description;
        @Spacing = 10;
        Padding: (Vertical: 8);
      }

      $LegendCommon.@TitledRow {
        @Name = %client.builderTools.legend.RevolveTool.Page2.Example2.Title;
        @Description = %client.builderTools.legend.RevolveTool.Page2.Example2.Description;
        @Spacing = 10;
        Padding: (Vertical: 8);
      }

    }

    $LegendCommon.@Page #Page3DecorationSettings {
      @Title = %client.builderTools.legend.RevolveTool.Page3.Title;

      $LegendCommon.@HotkeyRow {
        @InputBindingKey = "OpenInventory";
        @Description = %client.builderTools.legend.EditInventoryProperties;
        Padding: (Vertical: 8);
      }

      $LegendCommon.@RowLabel {
        Text: %client.builderTools.legend.SettingDescription;
        Padding: (Vertical: 8);
      }

      $LegendCommon.@Separator {}

      $LegendCommon.@TitledRow {
        @Name = %client.builderTools.legend.RevolveTool.Page3.Sampling.Title;
        @Description = %client.builderTools.legend.RevolveTool.Page3.Sampling.Description;
      }

      $LegendCommon.@TitledRow {
        @Name = %client.builderTools.legend.RevolveTool.Page3.FullyRevolve.Title;
        @Description = %client.builderTools.legend.RevolveTool.Page3.FullyRevolve.Description;
      }

      $LegendCommon.@TitledRow {
        @Name = %client.builderTools.legend.RevolveTool.Page3.PlaceCount.Title;
        @Description = %client.builderTools.legend.RevolveTool.Page3.PlaceCount.Description;
      }

      $LegendCommon.@TitledRow {
        @Name = %client.builderTools.legend.RevolveTool.Page3.CenterAround.Title;
        @Description = %client.builderTools.legend.RevolveTool.Page3.CenterAround.Description;
      }

      $LegendCommon.@TitledRow {
        @Name = %client.builderTools.legend.RevolveTool.Page3.UseCustomDistance.Title;
        @Description = %client.builderTools.legend.RevolveTool.Page3.UseCustomDistance.Description;
      }

      $LegendCommon.@TitledRow {
        @Name = %client.builderTools.legend.RevolveTool.Page3.PlaceDistance.Title;
        @Description = %client.builderTools.legend.RevolveTool.Page3.PlaceDistance.Description;
      }

    }
  }
}
