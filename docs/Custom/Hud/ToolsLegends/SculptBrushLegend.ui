$LegendCommon = "ToolsLegendsCommon.ui";

$LegendCommon.@Legend {
  #Pages {
    $LegendCommon.@Page #Page1Basics {
      @Title = %client.builderTools.legend.SculptBrush.Page1.Title;

      $LegendCommon.@RowLabel {
        Text: %client.builderTools.legend.SculptBrush.Page1.Description;
      }

      $LegendCommon.@HotkeyRow {
        @InputBindingKey = "SecondaryItemAction";
        @LayoutMode = Top;
        @Description = %client.builderTools.legend.SculptBrush.Page1.MeltAwayBlocks;
      }

      $LegendCommon.@HotkeyRow {
        @InputBindingKey = "PrimaryItemAction";
        @Description = %client.builderTools.legend.SculptBrush.Page1.RaiseLayer;
      }

      $LegendCommon.@HotkeyRow {
        @InputBindingKey = "SecondaryItemAction";
        @InputBindingKeyPrefixBinding = "AlternatePlaySculptBrushModeModifier";
        @Description = %client.builderTools.legend.SculptBrush.Page1.Smooth;
      }

      $LegendCommon.@RowLabel {
        Text: %client.builderTools.legend.SculptBrush.Page1.MaterialSelectedDescription;
      }

      $LegendCommon.@HotkeyRow {
        @InputBindingKey = "PickBlock";
        @Description = %client.builderTools.legend.SculptBrush.Page1.SelectTargetMaterial;
      }

      $LegendCommon.@Separator {}

      $LegendCommon.@HotkeyRow {
        @InputBindingKey = "UndoItemAction";
        @Description = %client.builderTools.legend.SculptBrush.Page1.UndoLastBrush;
      }

      $LegendCommon.@HotkeyRow {
        @InputBindingKey = "RedoItemAction";
        @Description = %client.builderTools.legend.SculptBrush.Page1.RedoLastUndo;
      }

      $LegendCommon.@Separator {}

      $LegendCommon.@RowLabel {
        Text: %client.builderTools.legend.shiftFasterChange;
      }

      $LegendCommon.@DoubleHotkeyRow {
        @InputBindingKeyOne = "BrushIncreaseHeight";
        @InputBindingKeyTwo = "BrushDecreaseHeight";
        @Text = %client.builderTools.legend.changeHeight;
      }

      $LegendCommon.@DoubleHotkeyRow {
        @InputBindingKeyOne = "BrushIncreaseWidth";
        @InputBindingKeyTwo = "BrushDecreaseWidth";
        @Text = %client.builderTools.legend.changeWidth;
      }

      $LegendCommon.@Separator {}

      $LegendCommon.@HotkeyRow {
        @InputBindingKey = "OpenInventory";
        @Description = %client.builderTools.legend.SculptBrush.Page1.EditInventoryProperties;
      }
    }

    $LegendCommon.@Page #Page2Kernels {
      @Title = %client.builderTools.legend.SculptBrush.Page2.Title;

      $LegendCommon.@RowLabel {
        Text: %client.builderTools.legend.SculptBrush.Page2.Intro;
      }

      $LegendCommon.@Separator {}

      $LegendCommon.@TitledRow {
        @Name = %client.builderTools.legend.SculptBrush.Page2.Normal.Name;
        @Description = %client.builderTools.legend.SculptBrush.Page2.Normal.Description;
      }

      $LegendCommon.@TitledRow {
        @Name = %client.builderTools.legend.SculptBrush.Page2.Uniform.Name;
        @Description = %client.builderTools.legend.SculptBrush.Page2.Uniform.Description;
        @Spacing = 4;
      }

      $LegendCommon.@TitledRow {
        @Name = %client.builderTools.legend.SculptBrush.Page2.Gaussian.Name;
        @Description = %client.builderTools.legend.SculptBrush.Page2.Gaussian.Description;
        @Spacing = 4;
      }

      $LegendCommon.@TitledRow {
        @Name = %client.builderTools.legend.SculptBrush.Page2.Neighbor.Name;
        @Description = %client.builderTools.legend.SculptBrush.Page2.Neighbor.Description;
        @Spacing = 4;
      }

      $LegendCommon.@TitledRow {
        @Name = %client.builderTools.legend.SculptBrush.Page2.Square.Name;
        @Description = %client.builderTools.legend.SculptBrush.Page2.Square.Description;
        @Spacing = 4;
      }
    }

  }
}
