$C = "../Common.ui";

@NumberInput = Group {
  @Visible = false;
  @Left = 32;
  LayoutMode: Left;
  Anchor: (Left: @Left, Top: 6);
  Visible: @Visible;

  Label {
    Text: @Label;
    Anchor: (Top: 6, Left: 6, Right: 16);
    Style: $C.@DefaultLabelStyle;
  }

  $C.@NumberField #Input {
    @Anchor = (Width: 60, Left: 0, Right: 16);

    Format: (
      MaxDecimalPlaces: 2,
      Step: 0.5
    );
  }
};

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 532);

    #Title {
      $C.@Title {
        @Text = %server.customUI.biomeEditor.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Group #Name {
        LayoutMode: Middle;
        Anchor: (Bottom: 16);

        Label {
          Text: %server.customUI.biomeEditor.name;
          Anchor: (Top: 6, Left: 16, Right: 16);
          Style: $C.@DefaultLabelStyle;
        }

        $C.@TextField #Input {
          @Anchor = (Width: 350, Left: 16, Right: 16);
        }
      }

      Group #Pack {
        LayoutMode: Middle;
        Anchor: (Bottom: 16);

        Label {
          Text: %server.customUI.biomeEditor.pack;
          Anchor: (Top: 6, Left: 16, Right: 16);
          Style: $C.@DefaultLabelStyle;
        }

        $C.@TextField #Input {
          @Anchor = (Width: 350, Left: 16, Right: 16);
        }
      }

      Group #Group {
        LayoutMode: Middle;
        Anchor: (Bottom: 16);

        Label {
          Text: %server.customUI.biomeEditor.group;
          Anchor: (Top: 6, Left: 16, Right: 16);
          Style: $C.@DefaultLabelStyle;
        }

        $C.@TextField #Input {
          @Anchor = (Width: 350, Left: 16, Right: 16);
        }
      }

      Group #BiomeTemplate {
        LayoutMode: Middle;
        Anchor: (Bottom: 16);

        Label {
          Text: %server.customUI.biomeEditor.biomeTemplate;
          Anchor: (Top: 6, Left: 16, Right: 16);
          Style: $C.@DefaultLabelStyle;
        }

        $C.@DropdownBox #Input {
          @Anchor = (Width: 350, Left: 16, Right: 16);
        }
      }

      Group #WorldStructureTemplate {
        LayoutMode: Middle;
        Anchor: (Bottom: 16);

        Label {
          Text: %server.customUI.biomeEditor.worldStructureTemplate;
          Anchor: (Top: 6, Left: 16, Right: 16);
          Style: $C.@DefaultLabelStyle;
        }

        $C.@DropdownBox #Input {
          @Anchor = (Width: 350, Left: 16, Right: 16);
        }
      }

      Group {
        Anchor: (Vertical: 16, Height: 1);
        Background: #5e512c;
      }

      $C.@TextButton #LaunchButton {
        Text: %server.customUI.biomeEditor.launch;
      }
    }
  }
}

$C.@BackButton {}
