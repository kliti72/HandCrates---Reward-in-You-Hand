$C = "../../Common.ui";

Group {
  LayoutMode: Left;
  Anchor: (Bottom: 6);

  Label #Label {
    Anchor: (Left: 6, Right: 10, Width: 130);
    Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center, Wrap: true);
    TextTooltipStyle: $C.@DefaultTextTooltipStyle;
  }

  $C.@DropdownBox #Input {
    @Anchor = (Left: 0, Right: 8, Width: 360);
    Style: DropdownBoxStyle(
      ...$C.@DefaultDropdownBoxStyle,
      EntryTooltipStyle: $C.@DefaultTextTooltipStyle,
      PanelWidth: 360
    );
  }
}
