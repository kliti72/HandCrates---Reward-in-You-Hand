$C = "../../Common.ui";

Group {
  LayoutMode: Left;
  Anchor: (Bottom: 6);

  Label #Label {
    Anchor: (Left: 6, Right: 10, Width: 130);
    Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center, Wrap: true);
    TextTooltipStyle: $C.@DefaultTextTooltipStyle;
  }

  $C.@NumberField #Input {
    @Anchor = (Width: 130, Left: 0, Right: 8);
    Format: (MaxDecimalPlaces: 0, Step: 1, Placeholder: "0");
  }
}
